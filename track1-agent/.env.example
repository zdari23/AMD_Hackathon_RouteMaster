# .env.example — copy to .env and fill in your key
# Get a key at https://fireworks.ai (or use the hackathon-provided key on submission day)
FIREWORKS_API_KEY=your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Dev-time model IDs from Fireworks' current serverless catalog, used to
# demonstrate the methodology. For the actual hackathon, the Participant FAQ
# allows the MiniMax and Kimi K series on Fireworks — swap these for the
# IDs in the hackathon's ALLOWED_MODELS list before submitting.
MODEL_CHEAP=accounts/fireworks/models/minimax-m3
MODEL_EXPENSIVE=accounts/fireworks/models/kimi-k2p7-code
MODEL_JUDGE=accounts/fireworks/models/glm-5p2
